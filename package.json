{
  "name": "aegis-self-healing-system",
  "version": "1.0.0",
  "description": "A locally runnable, zero-cost, explainable self-healing distributed system",
  "scripts": {
    "build": "tsc",
    "dev": "concurrently -n monitor,healer,evaluator -c blue,green,yellow \"npm:dev:monitor\" \"npm:dev:healer\" \"npm:dev:evaluator\"",
    "dev:monitor": "ts-node-dev --respawn src/monitor/index.ts",
    "dev:healer": "ts-node-dev --respawn src/healer/index.ts",
    "dev:evaluator": "ts-node-dev --respawn src/evaluator/index.ts",
    "start": "concurrently -n monitor,healer,evaluator -c blue,green,yellow \"node dist/monitor/index.js\" \"node dist/healer/index.js\" \"node dist/evaluator/index.js\"",
    "build:services": "npm run build --workspaces",
    "monitor": "ts-node src/monitor/index.ts",
    "healer": "ts-node src/healer/index.ts",
    "evaluator": "ts-node src/evaluator/index.ts",
    "chaos": "bash chaos/inject-failures.sh"
  },
  "workspaces": [
    "services/*"
  ],
  "keywords": [
    "self-healing",
    "distributed-systems",
    "chaos-engineering",
    "anomaly-detection",
    "microservices"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/dockerode": "^3.3.47",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dockerode": "^4.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.1",
    "uuid": "^9.0.1"
  }
}
